<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.Base">#1E1E2E</Color>
    <Color x:Key="Color.Mantle">#181825</Color>
    <Color x:Key="Color.Surface0">#313244</Color>
    <Color x:Key="Color.Surface1">#45475A</Color>
    <Color x:Key="Color.Text">#CDD6F4</Color>
    <Color x:Key="Color.SubText">#A6ADC8</Color>
    <Color x:Key="Color.Muted">#6C7086</Color>
    <Color x:Key="Color.Green">#A6E3A1</Color>
    <Color x:Key="Color.Blue">#89B4FA</Color>
    <Color x:Key="Color.Peach">#FAB387</Color>
    <Color x:Key="Color.Red">#F38BA8</Color>

    <SolidColorBrush x:Key="Brush.App.Background" Color="{StaticResource Color.Base}" />
    <SolidColorBrush x:Key="Brush.App.Panel" Color="{StaticResource Color.Mantle}" />
    <SolidColorBrush x:Key="Brush.App.Surface" Color="{StaticResource Color.Surface0}" />
    <SolidColorBrush x:Key="Brush.App.SurfaceHover" Color="{StaticResource Color.Surface1}" />
    <SolidColorBrush x:Key="Brush.App.Text" Color="{StaticResource Color.Text}" />
    <SolidColorBrush x:Key="Brush.App.SubText" Color="{StaticResource Color.SubText}" />
    <SolidColorBrush x:Key="Brush.App.Muted" Color="{StaticResource Color.Muted}" />
    <SolidColorBrush x:Key="Brush.App.Accent" Color="{StaticResource Color.Green}" />
    <SolidColorBrush x:Key="Brush.App.Blue" Color="{StaticResource Color.Blue}" />
    <SolidColorBrush x:Key="Brush.App.Warning" Color="{StaticResource Color.Peach}" />
    <SolidColorBrush x:Key="Brush.App.Error" Color="{StaticResource Color.Red}" />
    <SolidColorBrush x:Key="Brush.Border.Focus" Color="{StaticResource Color.Green}" />
</ResourceDictionary>
