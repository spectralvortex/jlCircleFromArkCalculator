<Window x:Class="CircleFromArcCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Circle From Arc Calculator"
        Width="1060"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.App.Background}"
        FontFamily="{StaticResource Font.App}">
    <Grid Margin="{StaticResource Space.Window}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="0.85*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,24">
            <TextBlock Text="Circle from arc"
                       Foreground="{StaticResource Brush.App.Text}"
                       FontSize="32"
                       FontWeight="Bold" />
            <TextBlock Text="Calculate the full circle radius from chord AB and sagitta CD."
                       Foreground="{StaticResource Brush.App.SubText}"
                       FontSize="16"
                       Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{StaticResource Brush.App.Panel}"
                CornerRadius="{StaticResource Radius.Large}"
                Padding="{StaticResource Space.Panel}"
                Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Sketch"
                           Foreground="{StaticResource Brush.App.SubText}"
                           FontWeight="SemiBold"
                           FontSize="13" />

                <Viewbox Grid.Row="1" Stretch="Uniform" Margin="0,18">
                    <Canvas Width="520" Height="380">
                        <Ellipse x:Name="CircleShape"
                                 Stroke="{StaticResource Brush.App.Accent}"
                                 StrokeThickness="4" />
                        <Line x:Name="ChordLine"
                              Stroke="{StaticResource Brush.App.Text}"
                              StrokeThickness="4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Line x:Name="SagittaLine"
                              Stroke="{StaticResource Brush.App.Blue}"
                              StrokeThickness="4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Line x:Name="RadiusLine"
                              Stroke="{StaticResource Brush.App.Warning}"
                              StrokeThickness="2"
                              StrokeDashArray="4 4" />
                        <TextBlock x:Name="LabelA" Text="A" Foreground="{StaticResource Brush.App.Warning}" FontWeight="Bold" FontSize="28" />
                        <TextBlock x:Name="LabelB" Text="B" Foreground="{StaticResource Brush.App.Warning}" FontWeight="Bold" FontSize="28" />
                        <TextBlock x:Name="LabelC" Text="C" Foreground="{StaticResource Brush.App.Warning}" FontWeight="Bold" FontSize="28" />
                        <TextBlock x:Name="LabelD" Text="D" Foreground="{StaticResource Brush.App.Warning}" FontWeight="Bold" FontSize="28" />
                        <TextBlock x:Name="LabelO" Text="O" Foreground="{StaticResource Brush.App.Warning}" FontWeight="Bold" FontSize="22" />
                    </Canvas>
                </Viewbox>

                <TextBlock Grid.Row="2"
                           Text="AB is the chord. CD is the sagitta, measured at 90 degrees from the chord midpoint to the arc."
                           Foreground="{StaticResource Brush.App.SubText}"
                           TextWrapping="Wrap"
                           FontSize="14" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource Brush.App.Panel}"
                    CornerRadius="{StaticResource Radius.Large}"
                    Padding="{StaticResource Space.Panel}">
                <StackPanel>
                    <TextBlock Text="Measurements"
                               Foreground="{StaticResource Brush.App.SubText}"
                               FontWeight="SemiBold"
                               FontSize="13" />

                    <TextBlock Text="AB chord length (mm)"
                               Foreground="{StaticResource Brush.App.Text}"
                               FontSize="15"
                               Margin="0,18,0,8" />
                    <TextBox x:Name="ChordInput"
                             Style="{StaticResource ModernTextBox}"
                             Text="200"
                             TextChanged="InputChanged" />

                    <TextBlock Text="CD sagitta height (mm)"
                               Foreground="{StaticResource Brush.App.Text}"
                               FontSize="15"
                               Margin="0,18,0,8" />
                    <TextBox x:Name="SagittaInput"
                             Style="{StaticResource ModernTextBox}"
                             Text="35"
                             TextChanged="InputChanged" />

                    <Button Content="Calculate"
                            Style="{StaticResource PrimaryActionButton}"
                            Margin="0,22,0,0"
                            Click="CalculateClicked" />

                    <TextBlock x:Name="ValidationText"
                               Foreground="{StaticResource Brush.App.Error}"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource Brush.App.Panel}"
                    CornerRadius="{StaticResource Radius.Large}"
                    Padding="{StaticResource Space.Panel}"
                    Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="Results"
                               Foreground="{StaticResource Brush.App.SubText}"
                               FontWeight="SemiBold"
                               FontSize="13" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Radius"
                                   Foreground="{StaticResource Brush.App.SubText}"
                                   FontSize="16" />
                        <TextBlock x:Name="RadiusText"
                                   Grid.Column="1"
                                   Foreground="{StaticResource Brush.App.Text}"
                                   FontSize="24"
                                   FontWeight="Bold" />

                        <TextBlock Grid.Row="1"
                                   Text="Diameter"
                                   Foreground="{StaticResource Brush.App.SubText}"
                                   FontSize="16"
                                   Margin="0,16,0,0" />
                        <TextBlock x:Name="DiameterText"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Foreground="{StaticResource Brush.App.Text}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="24,16,0,0" />

                        <TextBlock Grid.Row="2"
                                   Text="Central angle"
                                   Foreground="{StaticResource Brush.App.SubText}"
                                   FontSize="16"
                                   Margin="0,16,0,0" />
                        <TextBlock x:Name="AngleText"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Foreground="{StaticResource Brush.App.Text}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="24,16,0,0" />
                    </Grid>

                    <Border Background="{StaticResource Brush.App.Surface}"
                            CornerRadius="{StaticResource Radius.Medium}"
                            Padding="16"
                            Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="Formula"
                                       Foreground="{StaticResource Brush.App.SubText}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="a = AB / 2"
                                       Foreground="{StaticResource Brush.App.Text}"
                                       FontFamily="Consolas"
                                       Margin="0,10,0,0" />
                            <TextBlock Text="R = (a^2 + CD^2) / (2 * CD)"
                                       Foreground="{StaticResource Brush.App.Text}"
                                       FontFamily="Consolas"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
