<Window x:Class="CircleFromArcCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CircleFromArcCalculator"
        mc:Ignorable="d"
        Title="jl{Circle From Arc Calculator}"
        Width="840"
        Height="740"
        MinWidth="840"
        MinHeight="740"
        ResizeMode="NoResize"
        Icon="app_icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.App.Background}"
        FontFamily="{StaticResource Font.App}">
    <Grid Margin="{StaticResource Space.Window}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="0.65*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="2" Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Circle from arc"
                           Foreground="{StaticResource Brush.App.Text}"
                           FontSize="32"
                           FontWeight="Bold" />
                <TextBlock Text="Calculate the full circle radius from chord AB and sagitta CD."
                           Foreground="{StaticResource Brush.App.SubText}"
                           FontSize="16"
                           Margin="0,6,0,0" />
            </StackPanel>

            <Image Source="app_icon_image_74x75.png"
                Grid.Column="1"
                Width="Auto"
                Height="Auto"
                Stretch="Uniform"
                Cursor="Hand"
                MouseLeftButtonUp="AboutIconClicked"
                ToolTip="About Circle From Arc Calculator" />
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{StaticResource Brush.App.Panel}"
                CornerRadius="{StaticResource Radius.Large}"
                Padding="{StaticResource Space.Panel}"
                Margin="0,0,18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Sketch"
                           Foreground="{StaticResource Brush.App.SubText}"
                           FontWeight="SemiBold"
                           FontSize="13" />

                <Viewbox Grid.Row="1" Grid.Column="0" Margin="0,18">
                    <Canvas Width="{x:Static local:MainWindow.CanvasWidth}" Height="{x:Static local:MainWindow.CanvasHeight}">
                        <Ellipse x:Name="CircleShape"
                                 Stroke="{StaticResource Brush.App.Accent}"
                                 StrokeThickness="3" />
                        <Line x:Name="ChordLine"
                              Stroke="{StaticResource Brush.App.Text}"
                              StrokeThickness="4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Line x:Name="SagittaLine"
                              Stroke="{StaticResource Brush.App.Blue}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Line x:Name="RadiusLine"
                              Stroke="{StaticResource Brush.App.Warning}"
                              StrokeThickness="2"
                              StrokeDashArray="4 4" />
                        <TextBlock x:Name="LabelA" Text="A" Foreground="{StaticResource Brush.App.Blue}" FontWeight="Bold" FontSize="26" />
                        <TextBlock x:Name="LabelB" Text="B" Foreground="{StaticResource Brush.App.Blue}" FontWeight="Bold" FontSize="26" />
                        <TextBlock x:Name="LabelC" Text="C" Foreground="{StaticResource Brush.App.Blue}" FontWeight="Bold" FontSize="26" />
                        <TextBlock x:Name="LabelD" Text="D" Foreground="{StaticResource Brush.App.Blue}" FontWeight="Bold" FontSize="26" />
                        <TextBlock x:Name="LabelO" Text="O" Foreground="{StaticResource Brush.App.Warning}" FontWeight="Bold" FontSize="24" />
                        <TextBlock x:Name="LabelX" Text="⨉" Foreground="{StaticResource Brush.App.Warning}" FontWeight="Bold" FontSize="22" />
                    </Canvas>
                </Viewbox>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="AB is the chord. CD is the sagitta, measured at 90 degrees from the chord midpoint to the arc."
                           Foreground="{StaticResource Brush.App.SubText}"
                           TextWrapping="Wrap"
                           FontSize="14" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource Brush.App.Panel}"
                    CornerRadius="{StaticResource Radius.Large}"
                    Padding="{StaticResource Space.Panel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Measurements"
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Foreground="{StaticResource Brush.App.SubText}"
                            FontWeight="SemiBold"
                            FontSize="13" />

                    <TextBlock Text="AB chord length (mm)"
                            Grid.Row="1"
                            Grid.Column="0"
                            Foreground="{StaticResource Brush.App.Text}"
                            FontSize="15"
                            Margin="0,18,20,0" />
                    <TextBox x:Name="ChordInput"
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ModernTextBox}"
                            Text="120"
                            TextAlignment="Center"
                            TextChanged="InputChanged" 
                            Margin="0,8,0,8"/>

                    <TextBlock Text="CD sagitta height (mm)"
                            Grid.Row="2"
                            Grid.Column="0"
                            Foreground="{StaticResource Brush.App.Text}"
                            FontSize="15"
                            Margin="0,18,0,8" />
                    <TextBox x:Name="SagittaInput"
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ModernTextBox}"
                            Text="35"
                            TextAlignment="Center"
                            TextChanged="InputChanged"
                            Margin="0,8,0,8" />

                    <TextBlock x:Name="ValidationText"
                            Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Foreground="{StaticResource Brush.App.Error}"
                            TextWrapping="Wrap"
                            Margin="0,0,0,0" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource Brush.App.Panel}"
                    CornerRadius="{StaticResource Radius.Large}"
                    Padding="{StaticResource Space.Panel}"
                    Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="Results"
                               Foreground="{StaticResource Brush.App.Accent}"
                               FontWeight="SemiBold"
                               FontSize="13" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Radius"
                                   Foreground="{StaticResource Brush.App.SubText}"
                                   FontSize="16"
                                   Margin="0,4,0,0" />
                        <TextBlock x:Name="RadiusText"
                                   Grid.Column="1"
                                   Foreground="{StaticResource Brush.App.Text}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   TextAlignment="Right"
                                   Margin="0,0,0,0" />

                        <TextBlock Grid.Row="1"
                                   Text="Diameter"
                                   Foreground="{StaticResource Brush.App.SubText}"
                                   FontSize="16"
                                   Margin="0,14,0,0" />
                        <TextBlock x:Name="DiameterText"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Foreground="{StaticResource Brush.App.Text}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   TextAlignment="Right"
                                   Margin="0,10,0,0" />

                        <TextBlock Grid.Row="2"
                                   Text="Central angle"
                                   Foreground="{StaticResource Brush.App.SubText}"
                                   FontSize="14"
                                   Margin="0,20,0,0" />
                        <TextBlock x:Name="AngleText"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Foreground="{StaticResource Brush.App.Text}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextAlignment="Right"
                                   Margin="0,16,0,0" />
                    </Grid>

                    <Border 
                        Grid.Column="1"
                        Canvas.Left="318"
                        Canvas.Top="18"
                        Background="{StaticResource Brush.App.Surface}"
                        BorderBrush="{StaticResource Brush.App.Muted}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Medium}"
                        Padding="14,12"
                        Margin="0,30,0,0">
                        <StackPanel>
                            <TextBlock Text="a = AB / 2"
                                        Foreground="{StaticResource Brush.App.Text}"
                                        FontFamily="Consolas"
                                        FontSize="16" />
                            <TextBlock Text="s = CD"
                                        Foreground="{StaticResource Brush.App.Text}"
                                        FontFamily="Consolas"
                                        FontSize="16"
                                        Margin="0,5,0,0" />
                            <TextBlock Text="r = (s² + a²) / (2s)"
                                        Foreground="{StaticResource Brush.App.Accent}"
                                        FontFamily="Consolas"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
